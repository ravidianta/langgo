generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String
  role              Role           @default(LEARNER)
  character         String         @default("momo")
  hearts            Int            @default(5)
  maxHearts         Int            @default(5)
  xp                Int            @default(0)
  level             Int            @default(1)
  streakDays        Int            @default(0)
  lastHeartRefill   DateTime?
  currentSubLevelId String?
  createdAt         DateTime       @default(now())
  progress          Progress[]
  attempts          QuizAttempt[]
  voiceAttempts     VoiceAttempt[]
}

model Unit {
  id     String  @id @default(uuid())
  name   String
  country String
  flag   String
  theme  String
  order  Int
  topics Topic[]
}

model Topic {
  id        String     @id @default(uuid())
  unitId    String
  name      String
  emoji     String
  order     Int
  unit      Unit       @relation(fields: [unitId], references: [id])
  subLevels SubLevel[]
}

model SubLevel {
  id          String     @id @default(uuid())
  topicId     String
  number      String
  label       String
  isBoss      Boolean    @default(false)
  isUnitBoss  Boolean    @default(false)
  isVoiceOnly Boolean    @default(false)
  order       Int
  topic       Topic      @relation(fields: [topicId], references: [id])
  questions   Question[]
  progress    Progress[]
}

model Question {
  id            String         @id @default(uuid())
  subLevelId    String
  prompt        String
  correctAnswer String
  type          QuestionType
  isVoice       Boolean        @default(false)
  options       String[]
  subLevel      SubLevel       @relation(fields: [subLevelId], references: [id])
  attempts      QuizAttempt[]
  voiceAttempts VoiceAttempt[]
}

model Progress {
  id          String   @id @default(uuid())
  userId      String
  subLevelId  String
  score       Int
  passed      Boolean
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  subLevel    SubLevel @relation(fields: [subLevelId], references: [id])
}

model QuizAttempt {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  userAnswer  String
  isCorrect   Boolean
  aiFeedback  String?
  attemptedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
}

model VoiceAttempt {
  id          String   @id @default(uuid())
  userId      String
  questionId  String
  transcript  String
  score       Int
  feedback    String
  attemptedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  question    Question @relation(fields: [questionId], references: [id])
}

enum Role {
  LEARNER
  ADMIN
}

enum QuestionType {
  MULTIPLE_CHOICE
  FREE_TEXT
  TRANSLATION
  VOICE
}